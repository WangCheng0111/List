<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="List.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:List.Views"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6"/>
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="SettingsPage_Title"
                   MaxWidth="1064"
                   Margin="36,24,36,0"
                   AutomationProperties.HeadingLevel="Level1"
                   Style="{StaticResource TitleTextBlockStyle}"/>

        <ScrollView Grid.Row="1"
                    Padding="36,0,36,0"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto">
            <Border>
                <StackPanel MaxWidth="1064" Spacing="{StaticResource SettingsCardSpacing}">
                    <TextBlock x:Uid="SettingsPage_SectionAppearance"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                    <toolkit:SettingsCard x:Uid="SettingsPage_ThemeCard">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="themeMode"
                                  SelectionChanged="OnThemeSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_ThemeLight" Tag="Light"/>
                            <ComboBoxItem x:Uid="SettingsPage_ThemeDark" Tag="Dark"/>
                            <ComboBoxItem x:Uid="SettingsPage_ThemeSystem" Tag="Default"/>
                        </ComboBox>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="SettingsPage_LanguageCard">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE774;"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="languageMode"
                                  SelectionChanged="OnLanguageSelectionChanged">
                            <ComboBoxItem Content="中文" Tag="zh-CN"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                        </ComboBox>
                    </toolkit:SettingsCard>

                    <InfoBar x:Name="languageRestartBar"
                             x:Uid="SettingsPage_RestartBar"
                             Severity="Warning"
                             IsOpen="False"
                             IsClosable="False"/>
                </StackPanel>
            </Border>
        </ScrollView>
    </Grid>
</Page>
