<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="List.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:List.Views"
    xmlns:models="using:List.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <CommandBar.Content>
                <TextBlock x:Uid="HomePage_Title"
                           Margin="12,8"
                           Style="{ThemeResource SubtitleTextBlockStyle}"/>
            </CommandBar.Content>
            <AppBarButton x:Uid="HomePage_AddButton"
                          Icon="Add"
                          Click="OnAddClick"/>
        </CommandBar>

        <!-- Menu list -->
        <GridView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Items}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="OnItemClick"
                  Padding="0,16,0,0">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:MenuItem">
                    <Grid Width="240" Height="280">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.Row="0"
                               Source="{x:Bind ImageRelativePath, Converter={StaticResource ImageConverter}}"
                               Stretch="UniformToFill"
                               VerticalAlignment="Center"/>
                        <Border Grid.Row="0"
                                Background="#99000000"
                                CornerRadius="4"
                                Padding="10,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8"
                                         Fill="{x:Bind Difficulty, Converter={StaticResource DifficultyBrushConverter}}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Difficulty, Converter={StaticResource DifficultyConverter}}"
                                           FontSize="11"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1"
                              Padding="12,8"
                              ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Bind Name}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind CookingTimeMinutes, Converter={StaticResource CookingTimeConverter}}"
                                           Opacity="0.6"
                                           FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="OnDeleteItemClick"
                                    CommandParameter="{x:Bind}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Empty state -->
        <StackPanel Grid.Row="1"
                    x:Name="emptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <FontIcon Glyph="&#xE8C1;" FontSize="48" Opacity="0.4"/>
            <TextBlock x:Uid="HomePage_EmptyState"
                       HorizontalAlignment="Center"
                       Opacity="0.6"/>
        </StackPanel>
    </Grid>
</Page>
