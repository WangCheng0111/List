<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="List.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:List"
    xmlns:conv="using:List.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <conv:RelativePathToImageConverter x:Key="ImageConverter"/>
            <conv:DifficultyToStringConverter x:Key="DifficultyConverter"/>
            <conv:DifficultyToBrushConverter x:Key="DifficultyBrushConverter"/>
            <conv:CookingTimeToStringConverter x:Key="CookingTimeConverter"/>
            <conv:StepIndexToHeaderConverter x:Key="StepHeaderConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
